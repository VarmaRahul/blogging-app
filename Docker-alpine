FROM python:3.12-alpine

# Install build dependencies for Alpine
RUN apk add --no-cache gcc musl-dev python3-dev libffi-dev

ENV PYTHONUNBUFFERED=1 \
  PYTHONDONTWRITEBYTECODE=1

WORKDIR /usr/src/app

# 1. Copy requirements from root to current WORKDIR
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 2. Copy everything (this includes the 'app/' folder)
COPY . .

# 3. Execution (Must point to the folder containing manage.py)
# Since WORKDIR is /usr/src/app and manage.py is in 'app/', 
# the path is app/manage.py
CMD ["python", "app/manage.py", "runserver", "0.0.0.0:8000"]